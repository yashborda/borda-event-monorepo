# App
NODE_ENV=development # production | staging | development
PORT=3002

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=database
DB_SSL=false

# JWT — Website
# Generate with: openssl rand -hex 32
WEBSITE_JWT_ACCESS_SECRET=change-me-website-access-secret-min-32-chars
WEBSITE_JWT_REFRESH_SECRET=change-me-website-refresh-secret-min-32-chars

# JWT — Admin
# Generate with: openssl rand -hex 32
ADMIN_JWT_ACCESS_SECRET=change-me-admin-access-secret-min-32-chars
ADMIN_JWT_REFRESH_SECRET=change-me-admin-refresh-secret-min-32-chars

# Google OAuth — Website
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: http://localhost:3000/api/website/auth/google/callback
WEBSITE_GOOGLE_CLIENT_ID=
WEBSITE_GOOGLE_CLIENT_SECRET=
WEBSITE_GOOGLE_CALLBACK_URL=http://localhost:3000/api/website/auth/google/callback

# Google OAuth — Admin
# Authorized redirect URI must be: http://localhost:3001/api/admin/auth/google/callback
ADMIN_GOOGLE_CLIENT_ID=
ADMIN_GOOGLE_CLIENT_SECRET=
ADMIN_GOOGLE_CALLBACK_URL=http://localhost:3001/api/admin/auth/google/callback

# Mail
# For local development, use Mailpit: https://github.com/axllent/mailpit
# Run: docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
# View emails at: http://localhost:8025
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Borda Event <noreply@bordaevent.com>"

# For production with Resend:
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=465
# MAIL_USER=resend
# MAIL_PASSWORD=re_xxxxxxxxxxxx

# App URLs
APP_URL=http://localhost:3002
WEBSITE_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Cookies
# Set to true in production (requires HTTPS)
COOKIE_SECURE=false

# Website revalidation (on-demand ISR)
# Generate secret with: openssl rand -hex 32
WEBSITE_REVALIDATE_URL=http://localhost:3000/api/revalidate
WEBSITE_REVALIDATE_SECRET=change-me-revalidate-secret

# Cloudflare R2 media storage (S3-compatible)
# Account ID is the hex string in your R2 dashboard URL.
# Create an API token at R2 → Manage R2 API Tokens (Object Read & Write).
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET=your-bucket-name
# Enable in bucket → Settings → Public Development URL, or use a custom domain.
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
