# Environment variable
NEXT_PUBLIC_ENVIRONMENT=development # production | staging | development

# The base URL of the website, used for generating absolute URLs in emails, sitemaps, etc.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API base URL for server-side data fetching (not exposed to the browser)
BACKEND_INTERNAL_URL=http://localhost:3002

# Must match WEBSITE_REVALIDATE_SECRET in backend .env
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=change-me-revalidate-secret

# Google Analytics (optional — leave blank to disable analytics)
# Add your Google Analytics 4 Measurement ID (starts with G-)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
